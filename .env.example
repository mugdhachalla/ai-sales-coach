# Copy this file to .env and fill in your real values.
# Required: Hugging Face API token used by InferenceClient in app.py
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SECRET_KEY=your_secret_key_here
APP_MODE=local

# Flask configuration (optional for local development)
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1